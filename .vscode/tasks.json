{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure (macos debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "macos-debug"
      ]
    },
    {
      "label": "build (macos debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "macos-debug"
      ]
    },
    {
      "label": "run (macos debug)",
      "type": "shell",
      "command": "${workspaceFolder}/build/native/macos/debug/App",
      "problemMatcher": []
    },
    {
      "label": "configure, build, run (macos debug)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "configure (macos debug)",
        "build (macos debug)",
        "run (macos debug)"
      ]
    },
    {
      "label": "build, run (macos debug)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build (macos debug)",
        "run (macos debug)"
      ]
    },
    {
      "label": "configure (web)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "debug (web)"
      ]
    },
    {
      "label": "build (web)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "debug (web)"
      ]
    },
    {
      "label": "run (web)",
      "type": "shell",
      "command": "python3",
      "args": ["-m", "http.server", "8000"],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "open (web browser)",
      "type": "shell",
      "command": "open",
      "args": ["http://localhost:8000/build/web/debug/App.html"],
      "problemMatcher": []
    },
    {
      "label": "configure, build, run (web)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "configure (web)",
        "build (web)",
        "run (web)"
      ],
      "problemMatcher": []
    },
    
  ]
}